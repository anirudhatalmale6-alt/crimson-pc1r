			                   ExternalAccess := None,
			                   DefaultData := 0);
			PrevMonth : DINT (RADIX := Decimal,
			                    ExternalAccess := None,
			                    DefaultData := 0);
			PrevDay : DINT (RADIX := Decimal,
			                  ExternalAccess := None,
			                  DefaultData := 0);
