			                  DefaultData := 0);
			InitDone : BOOL (RADIX := Decimal,
			                   ExternalAccess := None,
			                   DefaultData := 0);
		END_LOCAL_TAGS

		ST_ROUTINE Logic 
			'(*
			'  AOI ST Routine - corrected for Logix v20 BOOL handling:
			'  - Use 1/0 for BOOL assignments
			'  - Do NOT compare BOOLs to 1/0 in IF expressions
			'
			'  INPUT parameters (exact):
			'    MachineRun : BOOL
			'    ClockMinutes : DINT
			'    ClockDay : DINT
			'    ClockMonth : DINT
			'    Reset : BOOL
			'
			'  OUTPUT parameters (exact):
			'    CurrentRunMinutes : DINT
			'    YesterdayRunMinutes : DINT
			'    isMonthRunMinutes : DINT
			'    LastMonthRunMinutes : DINT
			'
			'  Local Tags required (exact):
			'    InitDone : BOOL
			'    PrevMin : DINT
			'    PrevDay : DINT
			'    PrevMonth : DINT
			'    DeltaMin : DINT
			'    ResetMem : BOOL
			'*)
			'
			'(* ---------- Initialization ---------- *)
			'IF NOT InitDone THEN
			'
			'    PrevMin := ClockMinutes;
			'    PrevDay := ClockDay;
			'    PrevMonth := ClockMonth;
			'
			'    CurrentRunMinutes := 0;
			'    YesterdayRunMinutes := 0;
			'    isMonthRunMinutes := 0;
			'    LastMonthRunMinutes := 0;
			'
			'    ResetMem := Reset;
			'    InitDone := 1;
			'
			'END_IF;
			'
			'
			'(* ---------- Reset Rising Edge ---------- *)
			'IF (Reset AND NOT ResetMem) THEN
			'
			'    CurrentRunMinutes := 0;
			'    YesterdayRunMinutes := 0;
			'    isMonthRunMinutes := 0;
			'    LastMonthRunMinutes := 0;
			'
			'    (* Reseed previous clock values to prevent a big delta after reset *)
			'    PrevMin := ClockMinutes;
			'    PrevDay := ClockDay;
			'    PrevMonth := ClockMonth;
			'
			'END_IF;
			'
			'ResetMem := Reset;
			'
			'
			'(* ---------- Month Change ---------- *)
			'IF (ClockMonth <> PrevMonth) THEN
			'
			'    LastMonthRunMinutes := isMonthRunMinutes;
			'    isMonthRunMinutes := 0;
			'
			'    PrevMonth := ClockMonth;
			'
			'END_IF;
			'
			'
			'(* ---------- Day Change ---------- *)
			'IF (ClockDay <> PrevDay) THEN
			'
			'    YesterdayRunMinutes := CurrentRunMinutes;
			'    CurrentRunMinutes := 0;
			'
			'    PrevDay := ClockDay;
			'
			'END_IF;
			'
			'
			'(* ---------- Minute Tick / Accumulation ---------- *)
			'IF (ClockMinutes <> PrevMin) THEN
			'
			'    (* Minutes advanced since last scan; handle midnight wrap *)
			'    DeltaMin := ClockMinutes - PrevMin;
			'    IF (DeltaMin < 0) THEN
			'        DeltaMin := DeltaMin + 1440;
			'    END_IF;
			'
			'    (* Optional clamp against clock adjustments *)
			'    IF (DeltaMin > 60) THEN
			'        DeltaMin := 1;
			'    END_IF;
			'
			'    IF MachineRun THEN
			'        CurrentRunMinutes := CurrentRunMinutes + DeltaMin;
			'        isMonthRunMinutes := isMonthRunMinutes + DeltaMin;
			'    END_IF;
			'
			'    PrevMin := ClockMinutes;
			'
			'END_IF;
		END_ST_ROUTINE

	END_ADD_ON_INSTRUCTION_DEFINITION

