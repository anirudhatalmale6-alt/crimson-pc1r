	END_TAG

	PROGRAM MainProgram (MAIN := "MainProgram",
	                     MODE := 0,
	                     DisableFlag := 0)
			TAG
			END_TAG

			ROUTINE Get_Day_Of_Week 
					N: NOP();
					RC: "Get the Controllers real time clock broken down by Year, month, day...microseconds and store in a tag so that the values can be used.";
					N: XIC(Test_CurrentDate)GSV(WallClockTime,?,DateTime,TestDateTime.Year);
					N: MOV(TestDateTime.Year,TestDateTime.Year)MOV(TestDateTime.Month,TestDateTime.Month)MOV(TestDateTime.Day,TestDateTime.Day)MOV(TestDateTime.Hour,TestDateTime.Hour)MOV(TestDateTime.Minute,TestDateTime.Minute)MOV(TestDateTime.Second,TestDateTime.Second);
					N: JSR(Time_Date_Data,1,TestDateTime,Test_Result)MOV(Test_Result,Test_Result);
			END_ROUTINE

			ROUTINE M1_Monitoring 
					N: OTE(M1.Running);
					N: Machine_Time(M1_Machine_Run_Time,M1.Running,DOW_InputDate.Minute,DOW_InputDate.Day,DOW_InputDate.Month,M1.Reset,M1.CurrentRunMinutes,M1.Yesterday,M1.Month_Total,M1.Last_Month_Total);
					N: [XIC(HMI_Panel_IO[0].0) ONS(B3[20].0) XIC(M1_Point_Motor1:I.TripPresent) XIO(M1_Reset_Lockout) [OTE(M1_Point_Motor1:O.TripReset) ,CTU(C5[1],?,?) ] ,XIC(M1.Running) ONS(B3[20].3) RES(C5[1]) ,XIC(C5[1].DN) [OTE(M1_Reset_Lockout) ,TON(T4[20],?,?) ,XIC(T4[20].DN) RES(C5[1]) ] ,XIC(M1_Point_Motor1:I.TripPresent) OTE(B3[20].1) ];
					N: XIC(M1_Point_Motor1:I.Ready)OTE(HMI_Panel_IO[10].0);
			END_ROUTINE

			ROUTINE M2_Monitoring 
					N: OTE(M2.Running);
					N: Machine_Time(M2_Machine_Run_Time,M2.Running,DOW_InputDate.Minute,DOW_InputDate.Day,DOW_InputDate.Month,M1.Reset,M2.CurrentRunMinutes,M2.Yesterday,M2.Month_Total,M2.Last_Month_Total);
			END_ROUTINE

			ROUTINE M3_Monitoring 
					N: OTE(M3.Running);
					N: Machine_Time(M3_Machine_Run_Time,M3.Running,DOW_InputDate.Minute,DOW_InputDate.Day,DOW_InputDate.Month,M1.Reset,M3.CurrentRunMinutes,M3.Yesterday,M3.Month_Total,M3.Last_Month_Total);
			END_ROUTINE

			ROUTINE MainControl 
					RC: "The Micrologix 1100  used these outputs O:0/0 AUTO_PILOT_LT $N"
					    " O:0/1 FAULT_PILOT_LT  $N"
					    "O:0/2 BEACON_PILOT_LT  $N"
					    "O:0/3 MS1 Point Motor StarterCoil  $N"
					    "O:0/4 MS2 Chamfer MotorStarter Coil  $N"
					    "O:0/5 MS3 Coolant Pump MotorStarter Coil  $N"
					    "These were on the actual CPU Module$N"
					    "They are now outputs on slot 3 1759-OW16";
					N: NOP();
					RC: "The Micrologix 1100  used these inputs$N"
					    "I:0/0 ESR Emergency Stop Relay Input      $N"
					    "I:0/1 MS1 MS2 AUX Point & Chamfer Motor Starter Auxiliaries In Series    $N"
					    "I:0/2 AUTO STOP PB Operator Auto Stop PB      $N"
					    "I:0/3 MS3 AUX Coolant Pump Motor Starter Auxiliary      $N"
					    "I:0/4 MANUAL SELECTED Auto Manual Selector Switch      $N"
					    "I:0/5 AUTO START PB        $N"
					    "I:0/6 POINT MANUAL PB        $N"
					    "I:0/7 CHAMFER MANUAL PB        $N"
					    "I:0/8 VICES CLOSE PB        $N"
					    "I:0/9 VICES OPEN PB       $N"
					    "These were on the actual CPU Module and are now slot$N"
					    "$N"
					    "";
					N: NOP();
					RC: "MANUAL VICE OPEN/CLOSE LOGIC$N"
					    "A ROD MUST BE IN POSITION TO CLOSE THE CLAMP. ";
					N: XIC(InputModule1.Data.4)XIC(InputModule2.Data.0)XIO(InputModule1.Data.9)[XIC(InputModule1.Data.8) ,XIC(OutputModule3.Data.0) ]OTE(B3[0].2);
					RC: "ADD A TIME DELAY FOR THE ROD TO SETTLE IN AUTO MODE BEFORE CLOSING THE VICES";
					N: XIC(InputModule2.Data.0)TON(T4[0],?,?);
					N: XIC(OutputModule3.Data.9)XIO(InputModule2.Data.14)XIC(T4[0].DN)XIC(InputModule4.Data.1)XIC(InputModule4.Data.5)[XIO(B3[2].8) ,XIC(B3[2].7) ]OTE(B3[1].2);
					N: [XIC(B3[0].2) ,XIC(B3[1].2) ]XIC(InputModule1.Data.0)OTE(OutputModule3.Data.0);
					RC: "CHECK THAT THE VICES ARE WORKING CORRECTLY. THIS TIMER WILL GENERATE A FAULT IF THE VICES ARE NOT WORKING CORRECTLY";
					N: [XIC(InputModule1.Data.0) XIC(OutputModule3.Data.0) XIO(InputModule2.Data.3) ,XIO(OutputModule3.Data.0) [XIO(InputModule2.Data.2) ,XIO(InputModule2.Data.4) ] ]TON(T4[6],?,?);
					N: XIC(InputModule1.Data.0)XIC(T4[6].DN)XIC(OutputModule3.Data.0)XIO(InputModule2.Data.3)OTL(N7[0].0);
					N: XIC(InputModule1.Data.0)XIC(T4[6].DN)XIO(OutputModule3.Data.0)[XIO(InputModule2.Data.2) OTL(N7[0].4) ,XIO(InputModule2.Data.4) OTL(N7[1].8) ];
					N: XIC(InputModule1.Data.4)XIC(InputModule1.Data.6)XIO(B3[0].4)OTU(B3[2].4);
					N: XIC(InputModule1.Data.0)XIC(InputModule1.Data.4)XIO(InputModule1.Data.6)OTE(B3[0].4);
					N: XIC(InputModule1.Data.0)XIC(InputModule2.Data.9)OTE(OutputModule3.Data.12);
					N: XIC(OutputModule3.Data.12)TON(T4[18],?,?);
					N: XIC(InputModule1.Data.0)XIC(OutputModule3.Data.12)XIC(OutputModule3.Data.13)XIO(InputModule1.Data.1)TON(T4[10],?,?);
					N: XIC(T4[10].DN)OTL(N7[0].1);
					N: XIC(OutputModule3.Data.12)XIC(OutputModule3.Data.13)XIC(InputModule1.Data.1)TON(T4[1],?,?);
					N: XIC(T4[1].DN)[XIC(OutputModule3.Data.9) XIC(InputModule2.Data.3) XIC(T4[9].DN) XIC(T4[0].DN) ,XIC(B3[0].4) ]XIC(InputModule4.Data.1)XIC(InputModule4.Data.5)XIO(InputModule2.Data.6)XIC(B3[2].4)OTE(OutputModule3.Data.7);
					N: XIC(T4[1].DN)XIC(InputModule2.Data.6)OTL(B3[2].4);
					N: XIC(B3[2].4)TON(T4[7],?,?);
					N: XIC(OutputModule3.Data.9)XIO(InputModule2.Data.14)XIC(B3[2].4)XIC(T4[7].DN)OTE(B3[2].7);
					N: XIO(OutputModule3.Data.9)XIO(InputModule2.Data.14)XIC(B3[2].4)XIC(T4[7].DN)OTE(B3[1].7);
					N: XIC(InputModule1.Data.4)XIO(InputModule1.Data.7)XIC(B3[0].6)OTU(B3[2].6);
					N: XIC(InputModule1.Data.0)XIO(InputModule1.Data.4)XIC(InputModule1.Data.7)OTU(B3[0].6);
					N: XIC(InputModule1.Data.0)XIC(InputModule2.Data.9)XIC(T4[18].DN)OTU(OutputModule3.Data.13);
					N: XIC(T4[1].DN)[XIC(OutputModule3.Data.9) XIC(T4[9].DN) XIC(T4[0].DN) XIC(InputModule2.Data.3) ,XIC(B3[0].6) ]XIC(InputModule4.Data.1)XIC(InputModule4.Data.5)XIO(InputModule2.Data.8)XIO(B3[2].6)OTE(OutputModule3.Data.8);
					N: XIC(T4[1].DN)XIC(InputModule2.Data.8)OTL(B3[2].6);
					N: XIC(B3[2].6)TON(T4[8],?,?);
					N: XIC(OutputModule3.Data.9)XIO(InputModule2.Data.14)XIC(B3[2].6)XIC(T4[8].DN)OTE(B3[2].8);
					N: XIO(OutputModule3.Data.9)XIO(InputModule2.Data.14)XIC(B3[2].6)XIC(T4[8].DN)OTE(B3[1].8);
					N: XIC(InputModule1.Data.0)XIC(InputModule2.Data.7)OTE(OutputModule3.Data.14);
					N: XIC(InputModule1.Data.0)XIC(OutputModule3.Data.14)XIC(InputModule1.Data.3)TON(T4[12],?,?);
					N: XIC(T4[12].DN)OTE(N7[0].3);
					N: XIC(OutputModule3.Data.14)TON(T4[9],?,?);
					N: XIC(InputModule2.Data.1)TON(T4[2],?,?);
					N: XIC(InputModule1.Data.0)XIC(InputModule1.Data.4)XIC(T4[2].DN)[XIC(InputModule2.Data.11) XIO(InputModule2.Data.12) XIC(InputModule2.Data.15) ,XIC(B3[0].3) XIO(T4[5].DN) ]OTE(B3[0].3);
					N: XIC(InputModule1.Data.0)[XIC(InputModule1.Data.4) XIC(B3[0].3) ,XIC(B3[2].1) ]XIC(T4[2].DN)ONS(B3[2].14)OTL(OutputModule3.Data.5);
					N: XIC(OutputModule3.Data.5)TON(T4[11],?,?);
					N: [XIC(T4[11].DN) ,XIO(InputModule1.Data.0) ]OTU(OutputModule3.Data.5);
					N: [XIC(B3[0].3) ,XIC(T4[2].DN) XIC(InputModule4.Data.1) XIC(InputModule4.Data.5) [XIC(InputModule2.Data.11) XIO(InputModule2.Data.12) ,XIC(B3[2].1) ] XIO(B3[2].9) XIC(B3[1].3) ]OTE(B3[2].1);
					N: XIC(B3[2].1)XIC(T4[4].DN)OTE(OutputModule3.Data.3);
					N: XIC(B3[2].1)TON(T4[3],?,?);
					N: XIC(T4[3].DN)OTE(B3[2].2);
					N: XIC(B3[2].2)OTE(OutputModule3.Data.4);
					N: XIC(OutputModule3.Data.4)TON(T4[4],?,?);
					N: XIC(T4[4].DN)XIO(OutputModule3.Data.4)TON(T4[5],?,?);
					N: XIC(B3[1].3)XIC(T4[5].DN)OTL(B3[2].9);
					N: XIO(B3[1].3)XIC(T4[5].DN)OTE(B3[1].6);
					N: XIC(InputModule1.Data.0)XIO(OutputModule3.Data.3)XIO(OutputModule3.Data.4)[XIO(InputModule2.Data.11) ,XIO(InputModule2.Data.12) ]TON(T4[13],?,?);
					N: XIC(T4[13].DN)XIO(InputModule2.Data.11)OTL(N7[0].5);
					N: XIC(T4[13].DN)XIO(InputModule2.Data.12)OTL(N7[0].6);
					N: XIC(InputModule1.Data.0)XIO(InputModule1.Data.4)[XIC(InputModule2.Data.7) XIC(InputModule2.Data.9) ,XIC(InputModule2.Data.14) ]XIC(InputModule1.Data.2)[XIC(InputModule1.Data.5) ,XIC(OutputModule3.Data.9) XIC(C5[0].DN) ]XIC(B3[0].14)OTE(OutputModule3.Data.9);
					N: XIC(OutputModule3.Data.9)[XIC(InputModule2.Data.13) ,XIO(InputModule2.Data.13) XIO(InputModule2.Data.14) ]OTE(B3[1].5);
					N: XIC(OutputModule3.Data.9)[XIO(InputModule2.Data.13) XIO(InputModule2.Data.14) ,XIC(InputModule2.Data.14) ]OTE(B3[1].3);
					N: XIC(OutputModule3.Data.9)[XIO(InputModule2.Data.14) XIO(InputModule2.Data.0) ,XIC(InputModule2.Data.14) XIO(InputModule2.Data.1) ,XIO(InputModule2.Data.14) XIC(InputModule2.Data.0) XIC(B3[2].8) XIC(B3[2].7) ,XIC(InputModule2.Data.14) XIC(InputModule2.Data.1) XIC(B3[2].9) ]OTE(B3[1].9);
					N: XIC(InputModule1.Data.0)XIC(InputModule1.Data.4)XIC(InputModule2.Data.10)OTE(B3[0].15);
					N: XIO(InputModule2.Data.0)XIC(B3[1].9)[OTU(B3[2].4) ,OTU(B3[2].6) ];
					N: XIO(InputModule2.Data.12)XIO(InputModule2.Data.11)XIO(InputModule2.Data.1)XIC(B3[1].9)OTU(B3[2].9);
					N: XIC(InputModule4.Data.1)XIC(InputModule4.Data.5)XIC(InputModule4.Data.3)XIC(InputModule4.Data.7)XIC(InputModule2.Data.11)XIO(InputModule2.Data.12)[XIC(B3[1].9) ,XIC(B3[0].15) ]XIO(OutputModule3.Data.0)XIO(InputModule2.Data.3)XIC(InputModule2.Data.2)XIC(InputModule2.Data.4)XIO(B3[1].12)OTL(B3[1].10);
					N: XIC(B3[1].10)OTE(OutputModule3.Data.1);
					N: XIC(B3[1].10)XIC(InputModule4.Data.0)XIC(InputModule4.Data.4)OTL(B3[1].11);
					N: XIC(B3[1].11)OTE(OutputModule3.Data.2);
					N: XIC(B3[1].11)XIC(InputModule4.Data.2)XIC(InputModule4.Data.6)XIC(InputModule4.Data.0)XIC(InputModule4.Data.4)OTL(B3[1].12);
					N: XIC(B3[1].12)OTU(B3[1].10);
					N: XIC(B3[1].12)XIC(InputModule4.Data.1)XIC(InputModule4.Data.5)XIC(InputModule4.Data.2)XIC(InputModule4.Data.6)OTU(B3[1].11);
					N: XIC(OutputModule3.Data.1)XIC(InputModule4.Data.1)XIC(InputModule4.Data.5)XIC(InputModule4.Data.3)XIC(InputModule4.Data.7)OTU(B3[1].12);
					N: XIO(OutputModule3.Data.1)[XIO(InputModule4.Data.1) ,XIO(InputModule4.Data.5) ,XIC(InputModule4.Data.0) ,XIC(InputModule4.Data.4) ]TON(T4[14],?,?);
					N: XIC(InputModule1.Data.0)XIC(T4[14].DN)[XIO(InputModule4.Data.1) OTL(N7[0].7) ,XIO(InputModule4.Data.5) OTL(N7[0].8) ,XIC(InputModule4.Data.0) OTL(N7[0].9) ,XIC(InputModule4.Data.4) OTL(N7[0].10) ];
					N: XIC(InputModule1.Data.0)XIC(OutputModule3.Data.1)[XIC(InputModule4.Data.1) ,XIC(InputModule4.Data.5) ,XIO(InputModule4.Data.0) ,XIO(InputModule4.Data.4) ]TON(T4[15],?,?);
					N: XIC(T4[15].DN)[XIC(InputModule4.Data.1) OTL(N7[0].11) ,XIC(InputModule4.Data.5) OTL(N7[0].12) ,XIO(InputModule4.Data.0) OTL(N7[0].13) ,XIO(InputModule4.Data.4) OTL(N7[0].14) ];
					N: XIC(OutputModule3.Data.2)[XIO(InputModule4.Data.3) ,XIO(InputModule4.Data.7) ,XIC(InputModule4.Data.2) ,XIC(InputModule4.Data.6) ]TON(T4[16],?,?);
					N: XIC(T4[16].DN)[XIO(InputModule4.Data.3) OTL(N7[0].15) ,XIO(InputModule4.Data.7) OTL(N7[1].0) ,XIC(InputModule4.Data.2) OTL(N7[1].1) ,XIC(InputModule4.Data.6) OTL(N7[1].2) ];
					N: XIC(InputModule1.Data.0)XIC(OutputModule3.Data.2)[XIO(InputModule4.Data.2) ,XIO(InputModule4.Data.6) ,XIC(InputModule4.Data.3) ,XIC(InputModule4.Data.7) ]TON(T4[17],?,?);
					N: XIC(T4[17].DN)[XIO(InputModule4.Data.2) OTL(N7[1].3) ,XIO(InputModule4.Data.6) OTL(N7[1].4) ,XIC(InputModule4.Data.3) OTL(N7[1].5) ,XIC(InputModule4.Data.7) OTL(N7[1].6) ];
					N: XIC(OutputModule3.Data.9)XIC(InputModule4.Data.7)XIC(InputModule4.Data.5)XIC(InputModule4.Data.1)XIC(InputModule4.Data.3)[XIO(InputModule2.Data.14) XIO(InputModule2.Data.0) ,XIC(InputModule2.Data.14) XIO(InputModule2.Data.1) ]CTU(C5[0],?,?);
					N: XIC(C5[0].DN)OTL(N7[1].7);
					N: [XIC(OutputModule3.Data.9) [XIO(InputModule2.Data.14) XIC(InputModule2.Data.0) ,XIC(InputModule2.Data.14) XIC(InputModule2.Data.1) ] ,XIC(InputModule1.Data.5) ,XIC(InputModule2.Data.5) XIC(N7[1].7) ]RES(C5[0]);
					N: [[XIC(InputModule2.Data.14) ,XIO(InputModule2.Data.14) XIO(InputModule2.Data.13) ] [XIC(OutputModule3.Data.9) XIC(B3[2].9) ,XIO(OutputModule3.Data.9) XIC(B3[1].6) ] ,XIC(InputModule2.Data.13) [XIC(OutputModule3.Data.9) XIC(B3[2].7) XIC(B3[2].8) ,XIO(OutputModule3.Data.9) XIC(B3[2].4) XIC(B3[2].6) XIC(B3[0].15) ] ]OTE(OutputModule3.Data.6);
					N: [XIO(InputModule1.Data.0) ,XIC(Flasher_Enable) XIC(Flasher_Fast) NEQ(N7[0],Zero) ,XIC(Flasher_Enable) XIC(Flasher_Fast) NEQ(N7[1],Zero) ,XIC(Flasher_Enable) XIC(Flasher_Slow) EQU(N7[0],Zero) EQU(N7[1],Zero) EQU(N7[2],Zero) ]OTE(OutputModule3.Data.10);
					N: XIC(InputModule2.Data.5)[MOV(Zero,N7[0]) ,MOV(Zero,N7[1]) ,MOV(Zero,N7[2]) ];
			END_ROUTINE

			ROUTINE MainProgram 
					N: JSR(MainControl,0)JSR(Get_Day_Of_Week,0)JSR(Production,0);
					N: JSR(M1_Monitoring,0)JSR(M2_Monitoring,0)JSR(M3_Monitoring,0)JSR(Misc_Utilities,0);
			END_ROUTINE

			ROUTINE Misc_Utilities 
					N: Program_Flasher(Flasher_Control,Flasher_Enable,Flasher_Slow,Flasher_Fast);
			END_ROUTINE

			ROUTINE Production 
					N: XIC(S:FS)[NEQ(DOW_InputDate.Month,N7[3]) ,NEQ(DOW_InputDate.Day,N7[4]) ]OTE(B3[0].1);
					N: XIC(S:FS)[MOV(DOW_InputDate.Month,N7[3]) ,MOV(DOW_InputDate.Day,N7[4]) ];
					N: [EQU(DOW_InputDate.Hour,Zero) ,XIC(B3[0].1) ]ONS(B3[0].8)[MOV(F8[6],F8[7]) ,MOV(F8[5],F8[6]) ,MOV(F8[4],F8[5]) ,MOV(F8[3],F8[4]) ,MOV(F8[2],F8[3]) ,MOV(F8[1],F8[2]) ,MOV(F8[0],F8[1]) ,MOV(Zero,F8[0]) ];
					N: XIC(OutputModule3.Data.6)OSR(B3[0].9,B3[0].10);
					N: XIC(B3[0].10)ADD(F8[0],One,F8[0]);
			END_ROUTINE

			ROUTINE Time_Date_Data 
					N: SBR(DOW_InputDate)NOP();
					N: NOP();
					RC: "Extract the two digit year within the century from the 4 digit year value. (Lower two digits)";
					N: MOV(DOW_InputDate.Day,DOW_Day)MOD(DOW_InputDate.Year,100,DOW_Year);
					RC: "Extract the two digit centurr from the 4 digit year value.  (Upper two digits)$N"
					    "";
					N: DIV(DOW_InputDate.Year,100,DOW_Temp00)TRN(DOW_Temp00,DOW_Century);
					RC: "For this calculation, the month of March = 1, Dec=10, and Jan/Feb are represented as months 11/12 from the previous year.";
					N: [GRT(DOW_InputDate.Month,2) SUB(DOW_InputDate.Month,2,DOW_Month) ,LEQ(DOW_InputDate.Month,2) ADD(DOW_InputDate.Month,10,DOW_Month) SUB(DOW_Year,1,DOW_Year) ];
					RC: "Here The century and 400 year corrections are built into The formula. $N"
					    "The TRN((2.6 *m) - 0.2) equation relates to the repetitive pattern that the 30-day months show when March is taken as The First month.$N"
					    "$N"
					    "Note that the Logix CPU$'s floating point math returns some values slightly different than expected which can change the final results.$N"
					    "Ex: 12 * 2.6 returns 31.199999 rather than 31.2.  To overcome this issue a value of 0.199999 is used in place of the 0.2 in the original equation.";
					N: MUL(2.6,DOW_Month,DOW_Temp01)SUB(DOW_Temp01,0.199999,DOW_Temp02)TRN(DOW_Temp02,DOW_Temp03);
					N: MUL(DOW_Century,2,DOW_Temp04);
					RC: "Leap Year Adjustment.";
					N: DIV(DOW_Year,4,DOW_Temp05)TRN(DOW_Temp05,DOW_Temp06);
					RC: "400 Year Adjustment.";
					N: DIV(DOW_Century,4,DOW_Temp07)TRN(DOW_Temp07,DOW_Temp08);
					RC: "Main part of equation... W = (k + floor(2.6m - 0.2) - 2C + Y + floor(Y/4) + floor(C/4)) mod 7$N"
					    "$N"
					    "DOW = DOW_Day + TRN((2.6 * DOW_Month) - 0.2) - (2 * DOW_Century) + DOW_Year + TRN(DOW_Year/4) + TRN(DOW_Century/4) MOD 7$N"
					    "$N"
					    "DOW_Temp03 =  TRN((2.6 * DOW_Month) - 0.2)$N"
					    "DOW_Temp04 = (2 * DOW_Century)$N"
					    "DOW_Temp06 = TRN(DOW_Year/4)$N"
					    "DOW_Temp08 = TRN(DOW_Century/4)$N"
					    "$N"
					    "DOW_Temp14 = (DOW_Day + DOW_Temp03 - DOW_Temp04 + DOW_Year + DOW_Temp06 +  DOW_Temp08) MOD 7$N"
					    "$N"
					    "";
					N: ADD(DOW_Day,DOW_Temp03,DOW_Temp09)SUB(DOW_Temp09,DOW_Temp04,DOW_Temp10)ADD(DOW_Temp10,DOW_Year,DOW_Temp11)ADD(DOW_Temp11,DOW_Temp06,DOW_Temp12)ADD(DOW_Temp12,DOW_Temp08,DOW_Temp13)MOD(DOW_Temp13,7,DOW_Temp14);
					RC: "MOD operation in some computers differ.  The equation provided in documentation above expects results from the MOD that are different than the actual results that the Logix5000$'s MOD instruction provide for values below the Divisor.  Because of this the logic below makes an adjustment to the the output from the MOD.";
					N: MOV(DOW_Temp14,DOW_Temp15)LES(DOW_Temp14,0)ADD(DOW_Temp14,7,DOW_Temp15);
					RC: "Trim off any fractional value to return the day of the week...";
					N: TRN(DOW_Temp15,DOW_Output)RET(DOW_Output);
			END_ROUTINE

	END_PROGRAM

	TASK MainTask (Type := CONTINUOUS,
	               Rate := 10,
	               Priority := 10,
	               Watchdog := 500,
	               DisableUpdateOutputs := No,
	               InhibitTask := No)
			MainProgram;
	END_TASK

CONFIG CST(SystemTimeMasterID := 0) END_CONFIG

CONFIG EthernetNetwork(SupervisorModeEnabled := 0,
	                                 SupervisorPrecedence := 0,
	                                 BeaconInterval := 400,
	                                 BeaconTimeout := 1960,
	                                 VLANID := 0) END_CONFIG

CONFIG EthernetPort1(PortEnabled := 1,
	                             AutoNegotiateEnabled := 1) END_CONFIG

CONFIG EthernetPort2(PortEnabled := 1,
	                             AutoNegotiateEnabled := 1) END_CONFIG

CONFIG InternetProtocol(ConfigType := Manual,
	                                   IPAddress := "192.168.16.20",
	                                   SubnetMask := "255.255.255.0",
	                                   Gateway := "192.168.16.1",
	                                   PrimaryDNS := "0.0.0.0",
	                                   SecondaryDNS := "0.0.0.0") END_CONFIG

CONFIG TimeSynchronize(Priority1 := 128,
	                                 Priority2 := 128,
	                                 PTPEnable := 0) END_CONFIG

CONFIG WallClockTime(LocalTimeAdjustment := 0,
	                     TimeZone := 0) END_CONFIG

END_CONTROLLER

