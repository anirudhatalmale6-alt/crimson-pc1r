	DATATYPE DateTime_Type (Description := "Structure for the DateTime from the Controller wallclock accessed by the GSV/SSV instruction",
	                        FamilyType := NoFamily)
		DINT Year;
		DINT Month (Description := "The month (1 - 12)");
		DINT Day (Description := "The day (1 - 31)");
		DINT Hour (Description := "hour (0 - 23)");
		DINT Minute (Description := "minute (0 - 59)");
		DINT Second (Description := "second (0 - 59)");
		DINT Microseconds (Description := "(0 - 999,999)");
	END_DATATYPE

	DATATYPE DOW_Test (FamilyType := NoFamily)
		DINT Year;
		DINT Month;
		DINT Day;
		DINT DOW;
	END_DATATYPE

	DATATYPE Runtime_Structure (FamilyType := NoFamily)
		SINT ZZZZZZZZZZRuntime_St0 (Hidden := 1);
		BIT Running ZZZZZZZZZZRuntime_St0 : 0;
		DINT Minutes;
		DINT Day;
		SINT ZZZZZZZZZZRuntime_St4 (Hidden := 1);
		BIT Reset ZZZZZZZZZZRuntime_St4 : 0;
		DINT CurrentRunMinutes;
		DINT Yesterday;
		DINT Month_Total;
		DINT Last_Month_Total;
	END_DATATYPE

